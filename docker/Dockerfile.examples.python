FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /app

RUN pip install --no-cache-dir \
    pyarrow \
    "grpcio>=1.50" \
    "protobuf>=3.19,<4"

# Copy the cmake-generated Python client stubs and examples
COPY client/python /app/client/python
COPY examples/python /app/examples/python
COPY examples/run_python_examples.sh /app/run_python_examples.sh

RUN chmod +x /app/run_python_examples.sh

ENTRYPOINT ["/app/run_python_examples.sh"]

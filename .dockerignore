.git
.gitmodules
.github

# Jetson builds use pre-installed system packages from the base image;
# non-Jetson builds compile Arrow/OTel from the vendored submodules.
# Only exclude submodules for Jetson (it uses its own Dockerfile anyway).

# Build directories and artifacts
build/
cmake-build-*/
out/

# IDE/editor settings
.idea/
.vscode/

# Local logs and runtime data
*.log
*.pid

# Dependency/cache directories
node_modules/
__pycache__/

# Large local package artifacts
*.deb

        "tags": [
          "PayloadCatalogService"
        ]
      },
      "post": {
        "summary": "Best-effort advisory that blocks spill while active.",
        "description": "Pin duration is in milliseconds. duration_ms=0 means indefinite pin until Unpin.",
        "operationId": "PayloadCatalogService_Pin",
        "responses": {
          "200": {
            "description": "A successful response.",

            }
          }
        },
        "parameters": [
          {
            "name": "id.value",
            "in": "path",
            "required": true,
            "type": "string",
            "format": "byte"
          },
          {
            "name": "force",
            "in": "query",
            "required": false,
            "type": "boolean"
          }
        ],
        "tags": [
          "PayloadCatalogService"
        ]
      }
    },
    "/v1/payloads/{id.value}/commit": {
      "post": {
        "summary": "Marks payload immutable and readable.\nAfter this point the payload must never change.",
        "operationId": "PayloadCatalogService_CommitPayload",

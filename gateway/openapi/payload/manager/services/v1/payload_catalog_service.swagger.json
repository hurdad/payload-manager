  ],
  "paths": {
    "/v1/payloads": {
      "get": {
        "summary": "Returns a summary row for every payload known to the service.\nOptionally filtered by tier.",
        "operationId": "PayloadCatalogService_ListPayloads",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListPayloadsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "tierFilter",
            "description": "Optional tier filter; TIER_UNSPECIFIED means return all tiers.\n\n - TIER_UNSPECIFIED: Not set; treated as an error in most contexts.\n - TIER_GPU: GPU device memory (fastest, smallest, most volatile).\n - TIER_RAM: Host DRAM / shared-memory segment.\n - TIER_DISK: Local NVMe/SSD/HDD (durable, larger, slower than RAM).\n - TIER_OBJECT: Remote object storage (S3/GCS/Azure; durable, largest).",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "TIER_UNSPECIFIED",
              "TIER_GPU",
              "TIER_RAM",
              "TIER_DISK",
              "TIER_OBJECT"
            ],
            "default": "TIER_UNSPECIFIED"
          },
          {
            "name": "pageSize",
            "description": "Maximum number of payloads to return. 0 = server default (50); max 500.",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pageToken",
            "description": "Opaque cursor from a previous ListPayloadsResponse.next_page_token.\nOmit or leave empty to start from the beginning.",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "PayloadCatalogService"
        ]
      },
      "post": {
        "summary": "Allocate reserves placement but the payload is invisible to readers\nuntil CommitPayload succeeds.",
        "operationId": "PayloadCatalogService_AllocatePayload",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1AllocatePayloadResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "description": "Allocate reserves placement but payload is not visible\nuntil CommitPayload succeeds.",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1AllocatePayloadRequest"
            }
          }
        ],
        "tags": [
          "PayloadCatalogService"
        ]
      }
    },
    "/v1/payloads/spill": {
      "post": {
        "summary": "Requests durable storage (usually disk/object storage).",
        "description": "BLOCKING policy waits until durable or failure.",
        "operationId": "PayloadCatalogService_Spill",

          }
        ],
        "tags": [
          "PayloadCatalogService"
        ]
      }
    },
    "/v1/payloads/{id.value}": {
      "delete": {
        "summary": "Deletes payload placement and metadata.",
        "description": "If force=true:\n- active leases are invalidated immediately\n- future reads must fail",
        "operationId": "PayloadCatalogService_Delete",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "type": "object",
              "properties": {}

          "type": "string",
          "format": "uint64"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "evictionPolicy": {
          "$ref": "#/definitions/v1EvictionPolicy",
          "title": "advisory eviction behavior only"
        }
      },
      "description": "Authoritative placement descriptor.\n\nversion increments whenever:\n- tier changes\n- location changes\n- lifecycle state changes\n\nClients MUST invalidate cached descriptors when version changes."
    },
    "v1PayloadID": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string",
          "format": "byte"
        }
      },
      "description": "Canonical payload identifier.\n\nMUST contain exactly 16 bytes (binary RFC4122 UUID).\nThe server rejects any other length.\n\nThis is intentionally NOT a string to avoid formatting ambiguity."
    },
    "v1PayloadMetadata": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/definitions/v1PayloadID"
        },
        "data": {
          "type": "string",
          "format": "byte"
        },
        "schema": {
          "type": "string"
        }
      },
      "description": "Opaque application metadata.\n\nThe payload manager stores but NEVER interprets this.\nKeep size small (KBs)."
    },
    "v1PayloadState": {
      "type": "string",
      "enum": [
        "PAYLOAD_STATE_UNSPECIFIED",
        "PAYLOAD_STATE_ALLOCATED",
        "PAYLOAD_STATE_ACTIVE",
        "PAYLOAD_STATE_SPILLING",
        "PAYLOAD_STATE_DURABLE",
        "PAYLOAD_STATE_EVICTING",
        "PAYLOAD_STATE_DELETING",
        "PAYLOAD_STATE_EXPIRED",
        "PAYLOAD_STATE_DELETED"
      ],
      "default": "PAYLOAD_STATE_UNSPECIFIED",
      "description": "Lifecycle states are monotonic.\nClients MUST NOT assume a reversible transition.\n\n - PAYLOAD_STATE_UNSPECIFIED: Not set; treated as an error.\n - PAYLOAD_STATE_ALLOCATED: Reserved; writer has not yet committed data.\n - PAYLOAD_STATE_ACTIVE: Committed and readable by consumers.\n - PAYLOAD_STATE_SPILLING: Being moved to a lower tier; temporarily locked.\n - PAYLOAD_STATE_DURABLE: Confirmed written to a durable tier (DISK/OBJECT).\n - PAYLOAD_STATE_EVICTING: Being removed from its current tier under pressure.\n - PAYLOAD_STATE_DELETING: Deletion in progress.\n - PAYLOAD_STATE_EXPIRED: TTL elapsed; pending final deletion.\n - PAYLOAD_STATE_DELETED: Fully deleted; ID is no longer valid."
    },
    "v1PayloadSummary": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/definitions/v1PayloadID"
        },
        "tier": {
          "$ref": "#/definitions/v1Tier"
        },
        "state": {
          "$ref": "#/definitions/v1PayloadState"
        },
        "sizeBytes": {
          "type": "string",
          "format": "uint64"
        },
        "createdAtMs": {
          "type": "string",
          "format": "uint64",
          "title": "0 = unknown (legacy row)"
        },
        "expiresAtMs": {
          "type": "string",
          "format": "uint64",
          "title": "0 = no expiration"
        },
        "activeLeases": {
          "type": "integer",
          "format": "int64"
        }
      },
      "description": "Summary row returned by ListPayloads."
    },
    "v1PromoteResponse": {
      "type": "object",
      "properties": {
        "payloadDescriptor": {
          "$ref": "#/definitions/v1PayloadDescriptor"
        }
      }
    },
    "v1PromotionPolicy": {
      "type": "string",
      "enum": [
        "PROMOTION_POLICY_UNSPECIFIED",
        "PROMOTION_POLICY_BEST_EFFORT",
        "PROMOTION_POLICY_BLOCKING"
      ],
      "default": "PROMOTION_POLICY_UNSPECIFIED",
      "description": "Promotion policy controls behavior when a payload must move to a higher tier.\n\n - PROMOTION_POLICY_BEST_EFFORT: Schedule asynchronously if possible\n - PROMOTION_POLICY_BLOCKING: RPC returns only when target tier satisfied or fails"
    },
    "v1RamLocation": {
      "type": "object",
      "properties": {
        "shmName": {
          "type": "string"
        },
        "slabId": {
          "type": "integer",
          "format": "int64"
        },
        "blockIndex": {
          "type": "string",
          "format": "uint64"
        },
        "lengthBytes": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "v1SpillPolicy": {
      "type": "string",
      "enum": [
        "SPILL_POLICY_UNSPECIFIED",
        "SPILL_POLICY_BEST_EFFORT",
        "SPILL_POLICY_BLOCKING"
      ],
      "default": "SPILL_POLICY_UNSPECIFIED",
      "description": "Spill policy controls durability operations.\n\n - SPILL_POLICY_BEST_EFFORT: Background durability\n - SPILL_POLICY_BLOCKING: Wait until durable or failure"
    },
    "v1SpillRequest": {
      "type": "object",
      "properties": {
        "ids": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1PayloadID"
          }
        },
        "policy": {
          "$ref": "#/definitions/v1SpillPolicy"
        },
        "waitForLeases": {
          "type": "boolean"
        },
        "fsync": {
          "type": "boolean"
        },
        "targetTier": {
          "$ref": "#/definitions/v1Tier",
          "description": "Optional override: spill to this tier instead of the per-payload default.\nMust be a tier below the payload's current tier."
        }
      }
    },
    "v1SpillResponse": {
      "type": "object",
      "properties": {
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/SpillResponseResult"
          }
        }
      }
    },
    "v1Tier": {
      "type": "string",
      "enum": [
        "TIER_UNSPECIFIED",
        "TIER_GPU",
        "TIER_RAM",
        "TIER_DISK",
        "TIER_OBJECT"
      ],
      "default": "TIER_UNSPECIFIED",
      "description": "Ordered from fastest → most durable.\nHigher tiers may not always be available.\n\n - TIER_UNSPECIFIED: Not set; treated as an error in most contexts.\n - TIER_GPU: GPU device memory (fastest, smallest, most volatile).\n - TIER_RAM: Host DRAM / shared-memory segment.\n - TIER_DISK: Local NVMe/SSD/HDD (durable, larger, slower than RAM).\n - TIER_OBJECT: Remote object storage (S3/GCS/Azure; durable, largest)."
    },
    "v1UpdatePayloadMetadataResponse": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/definitions/v1PayloadID"
        },
        "metadata": {
          "$ref": "#/definitions/v1PayloadMetadata"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}

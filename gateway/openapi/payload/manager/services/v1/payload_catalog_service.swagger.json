  "definitions": {
    "PayloadCatalogServiceAddLineageBody": {
      "type": "object",
      "properties": {
        "child": {
          "type": "object",
          "description": "Canonical payload identifier.\n\nMUST contain exactly 16 bytes (binary RFC4122 UUID).\nThe server rejects any other length.\n\nThis is intentionally NOT a string to avoid formatting ambiguity."
        },
        "parents": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1LineageEdge"
          }
        }
      }
    },
    "PayloadCatalogServiceAppendPayloadMetadataEventBody": {
      "type": "object",
      "properties": {
        "id": {
          "type": "object",
          "description": "Canonical payload identifier.\n\nMUST contain exactly 16 bytes (binary RFC4122 UUID).\nThe server rejects any other length.\n\nThis is intentionally NOT a string to avoid formatting ambiguity."
        },
        "metadata": {
          "$ref": "#/definitions/v1PayloadMetadata"
        },
        "source": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },

        "lengthBytes": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "v1LineageEdge": {
      "type": "object",
      "properties": {
        "parent": {
          "$ref": "#/definitions/v1PayloadID"
        },
        "operation": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "parameters": {
          "type": "string",
          "format": "byte"
        }
      },
      "description": "Descriptive relationships only.\nDoes NOT enforce execution ordering."
    },
    "v1ListPayloadsResponse": {
      "type": "object",
      "properties": {
        "payloads": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1PayloadSummary"
          }
        },
        "nextPageToken": {
          "type": "string",
          "description": "Opaque cursor for the next page. Empty when this is the last page."
        },
        "totalCount": {
          "type": "integer",
          "format": "int32",
          "description": "Total number of payloads matching the filter (ignoring pagination)."
        }
      }
    },
    "v1MetadataUpdateMode": {
      "type": "string",
      "enum": [
        "METADATA_UPDATE_MODE_UNSPECIFIED",
        "METADATA_UPDATE_MODE_MERGE",
        "METADATA_UPDATE_MODE_REPLACE"
      ],
      "default": "METADATA_UPDATE_MODE_UNSPECIFIED",
      "description": "Metadata update behavior.\nThis only affects stored opaque metadata — not placement state.\n\n - METADATA_UPDATE_MODE_MERGE: Implementation-defined merge semantics\n - METADATA_UPDATE_MODE_REPLACE: Replace entire metadata blob"
    },

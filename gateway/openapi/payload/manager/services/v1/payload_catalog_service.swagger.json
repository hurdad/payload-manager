        },
        "policy": {
          "$ref": "#/definitions/v1PromotionPolicy"
        }
      },
      "description": "BLOCKING policy waits until requested durability\nor definitive failure."
    },
    "PayloadCatalogServiceUpdatePayloadMetadataBody": {
      "type": "object",
      "properties": {
        "id": {
          "type": "object",
          "title": "Target payload"
        },
        "mode": {
          "$ref": "#/definitions/v1MetadataUpdateMode",
          "title": "How to apply update"
        },
        "metadata": {
          "$ref": "#/definitions/v1PayloadMetadata",
          "title": "New metadata"
        },
        "actor": {
          "type": "string",
          "title": "Optional attribution"
        },
        "reason": {

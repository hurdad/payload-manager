  "definitions": {
    "PayloadStreamServiceAppendBody": {
      "type": "object",
      "properties": {
        "stream": {
          "type": "object",
          "title": "============================================================================\nSTREAM IDENTITY\n----------------------------------------------------------------------------\nA logical name that remains stable across restarts.\nNamespace allows multi-tenant or multi-system isolation.\nTogether they uniquely identify a stream.\n============================================================================"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1AppendItem"
          }
        }
      },
      "description": "============================================================================\nAPPEND\n----------------------------------------------------------------------------\nAppends payload UUIDs in order received.\n\nGuarantees:\n  - items in request remain ordered\n  - requests serialized by server\n  - offsets assigned atomically\n\nIMPORTANT:\n  Producer must only append AFTER payload commit succeeds.\n============================================================================"
    },
    "PayloadStreamServiceCommitBody": {
      "type": "object",
      "properties": {
        "stream": {
          "type": "object",
          "title": "============================================================================\nSTREAM IDENTITY\n----------------------------------------------------------------------------\nA logical name that remains stable across restarts.\nNamespace allows multi-tenant or multi-system isolation.\nTogether they uniquely identify a stream.\n============================================================================"
        },
        "consumerGroup": {
          "type": "string"
        },
        "offset": {
          "type": "string",
          "format": "uint64"
        }
      },
      "description": "============================================================================\nCONSUMER GROUP CHECKPOINTS\n----------------------------------------------------------------------------\nEnables exactly-once style processing.\n\nConsumer commits last fully processed offset.\nServer stores position durably.\n============================================================================"
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1AppendItem": {
      "type": "object",
      "properties": {
        "payloadId": {
          "$ref": "#/definitions/v1PayloadID",
          "title": "must exist in payload manager"
        },
        "eventTime": {
          "type": "string",
          "format": "date-time"
        },
        "durationNs": {
          "type": "string",
          "format": "uint64"
        },
        "tags": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "v1AppendResponse": {
      "type": "object",
      "properties": {
        "firstOffset": {
          "type": "string",
          "format": "uint64"
        },
        "lastOffset": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "v1CreateStreamRequest": {
      "type": "object",
      "properties": {
        "stream": {
          "$ref": "#/definitions/v1StreamID"
        },
        "retentionMaxEntries": {
          "type": "string",
          "format": "uint64",
          "title": "retention expressed as logical history\nif zero -\u003e infinite retention"
        },
        "retentionMaxAgeSec": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "v1GetCommittedResponse": {
      "type": "object",
      "properties": {
        "offset": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "v1GetRangeResponse": {
      "type": "object",
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1StreamEntry"
          }
        }
      }
    },
    "v1PayloadID": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string",
          "format": "byte"
        }
      },
      "description": "Canonical payload identifier.\n\nMUST contain exactly 16 bytes (binary RFC4122 UUID).\nThe server rejects any other length.\n\nThis is intentionally NOT a string to avoid formatting ambiguity."
    },
    "v1ReadResponse": {
      "type": "object",
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1StreamEntry"
          }
        }
      }
    },
    "v1StreamEntry": {
      "type": "object",
      "properties": {
        "stream": {
          "$ref": "#/definitions/v1StreamID",
          "title": "stream identity"
        },
        "offset": {
          "type": "string",
          "format": "uint64",
          "title": "assigned by server at append time\nnever reused, never decreases"
        },
        "payloadId": {
          "$ref": "#/definitions/v1PayloadID",
          "title": "Canonical payload identity returned by PayloadManager::Commit"
        },
        "eventTime": {
          "type": "string",
          "format": "date-time",
          "title": "producer event timestamp (capture time)"
        },
        "appendTime": {
          "type": "string",
          "format": "date-time",
          "title": "when the stream committed the entry"
        },
        "durationNs": {
          "type": "string",
          "format": "uint64",
          "title": "logical playback duration of payload\nused for paced replay"
        },
        "tags": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "title": "lightweight routing/filter metadata"
        }
      },
      "description": "============================================================================\nSTREAM ENTRY\n----------------------------------------------------------------------------\nThe fundamental record stored in the commit log.\n\nOrdering rule:\n  Offsets are strictly monotonically increasing per stream.\n  Offset is the ONLY source of truth for ordering.\n  Timestamps must never be used for ordering.\n\nReplay rule:\n  Replaying the same offset range must produce identical sequence.\n\nDurability rule:\n  Entry is visible only AFTER payload is committed to PayloadManager.\n============================================================================"
    },
    "v1StreamID": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "title": "ex: \"rf.iq.radio0\", \"decoder.frames\""
        },
        "namespace": {
          "type": "string",
          "title": "optional tenant / environment"
        }
      },
      "title": "============================================================================\nSTREAM IDENTITY\n----------------------------------------------------------------------------\nA logical name that remains stable across restarts.\nNamespace allows multi-tenant or multi-system isolation.\nTogether they uniquely identify a stream.\n============================================================================"
    },
    "v1SubscribeResponse": {
      "type": "object",
      "properties": {
        "entry": {
          "$ref": "#/definitions/v1StreamEntry"
        }
      }
    }
  }
}

{
  "swagger": "2.0",
  "info": {
    "title": "payload/manager/services/v1/payload_data_service.proto",
    "version": "version not set"
  },
  "tags": [
    {
      "name": "PayloadDataService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/leases/{leaseId.value}": {
      "delete": {
        "operationId": "PayloadDataService_ReleaseLease",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "type": "object",
              "properties": {}
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "leaseId.value",
            "in": "path",
            "required": true,
            "type": "string",
            "format": "byte"
          }
        ],
        "tags": [
          "PayloadDataService"
        ]
      }
    },
    "/v1/payloads/{id.value}/lease": {
      "post": {
        "operationId": "PayloadDataService_AcquireReadLease",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1AcquireReadLeaseResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "id.value",
            "in": "path",
            "required": true,
            "type": "string",
            "format": "byte"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/PayloadDataServiceAcquireReadLeaseBody"
            }
          }
        ],
        "tags": [
          "PayloadDataService"
        ]
      }
    },
    "/v1/payloads/{id.value}/snapshot": {
      "get": {
        "operationId": "PayloadDataService_ResolveSnapshot",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ResolveSnapshotResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "id.value",
            "in": "path",
            "required": true,
            "type": "string",
            "format": "byte"
          }
        ],
        "tags": [
          "PayloadDataService"
        ]
      }
    }
  },
  "definitions": {
    "PayloadDataServiceAcquireReadLeaseBody": {
      "type": "object",
      "properties": {
        "id": {
          "type": "object",
          "description": "Canonical payload identifier.\n\nMUST contain exactly 16 bytes (binary RFC4122 UUID).\nThe server rejects any other length.\n\nThis is intentionally NOT a string to avoid formatting ambiguity."
        },
        "minTier": {
          "$ref": "#/definitions/v1Tier"
        },
        "promotionPolicy": {
          "$ref": "#/definitions/v1PromotionPolicy"
        },
        "minLeaseDurationMs": {
          "type": "string",
          "format": "uint64"
        },
        "mode": {
          "$ref": "#/definitions/v1LeaseMode"
        }
      },
      "description": "Safe read access."
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1AcquireReadLeaseResponse": {
      "type": "object",
      "properties": {
        "payloadDescriptor": {
          "$ref": "#/definitions/v1PayloadDescriptor"
        },
        "leaseId": {
          "$ref": "#/definitions/v1LeaseID"
        },
        "leaseExpiresAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "v1DiskLocation": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "offsetBytes": {
          "type": "string",
          "format": "uint64"
        },
        "lengthBytes": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "v1EvictionPolicy": {
      "type": "object",
      "properties": {
        "priority": {
          "$ref": "#/definitions/v1EvictionPriority",
          "title": "Relative eviction importance"
        },
        "requireDurable": {
          "type": "boolean",
          "title": "Require durable copy before removing from volatile tier"
        },
        "spillTarget": {
          "$ref": "#/definitions/v1Tier",
          "title": "Preferred durability tier (usually DISK)"
        },
        "minResidencyTier": {
          "$ref": "#/definitions/v1Tier",
          "title": "Attempt to keep payload at or above this tier"
        }
      },
      "description": "Advisory eviction hints.\n\nThese are not strict guarantees — the system MAY violate them\nunder critical resource pressure."
    },
    "v1EvictionPriority": {
      "type": "string",
      "enum": [
        "EVICTION_PRIORITY_UNSPECIFIED",
        "EVICTION_PRIORITY_LOW",
        "EVICTION_PRIORITY_NORMAL",
        "EVICTION_PRIORITY_HIGH",
        "EVICTION_PRIORITY_NEVER"
      ],
      "default": "EVICTION_PRIORITY_UNSPECIFIED",
      "description": " - EVICTION_PRIORITY_UNSPECIFIED: Treated as NORMAL.\n - EVICTION_PRIORITY_LOW: Evict before NORMAL candidates.\n - EVICTION_PRIORITY_NORMAL: Default eviction weight.\n - EVICTION_PRIORITY_HIGH: Evict only after LOW and NORMAL are exhausted.\n - EVICTION_PRIORITY_NEVER: Never automatically evicted (implies no_evict=true)."
    },
    "v1GpuLocation": {
      "type": "object",
      "properties": {
        "deviceId": {
          "type": "integer",
          "format": "int64"
        },
        "ipcHandle": {
          "type": "string",
          "format": "byte",
          "title": "opaque CUDA IPC handle"
        },
        "lengthBytes": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "v1LeaseID": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string",
          "format": "byte"
        }
      },
      "description": "Canonical lease identifier.\n\nMUST contain exactly 16 bytes (binary RFC4122 UUID).\nThe server rejects any other length.\n\nThis is intentionally NOT a string to avoid formatting ambiguity."
    },
    "v1LeaseMode": {
      "type": "string",
      "enum": [
        "LEASE_MODE_UNSPECIFIED",
        "LEASE_MODE_READ"
      ],
      "default": "LEASE_MODE_UNSPECIFIED"
    },
    "v1PayloadDescriptor": {
      "type": "object",
      "properties": {
        "payloadId": {
          "$ref": "#/definitions/v1PayloadID"
        },
        "tier": {
          "$ref": "#/definitions/v1Tier"
        },
        "state": {
          "$ref": "#/definitions/v1PayloadState"
        },
        "gpu": {
          "$ref": "#/definitions/v1GpuLocation"
        },
        "ram": {
          "$ref": "#/definitions/v1RamLocation"
        },
        "disk": {
          "$ref": "#/definitions/v1DiskLocation"
        },
        "version": {
          "type": "string",
          "format": "uint64"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "evictionPolicy": {
          "$ref": "#/definitions/v1EvictionPolicy",
          "title": "advisory eviction behavior only"
        }
      },
      "description": "Authoritative placement descriptor.\n\nversion increments whenever:\n- tier changes\n- location changes\n- lifecycle state changes\n\nClients MUST invalidate cached descriptors when version changes."
    },
    "v1PayloadID": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string",
          "format": "byte"
        }
      },
      "description": "Canonical payload identifier.\n\nMUST contain exactly 16 bytes (binary RFC4122 UUID).\nThe server rejects any other length.\n\nThis is intentionally NOT a string to avoid formatting ambiguity."
    },
    "v1PayloadState": {
      "type": "string",
      "enum": [
        "PAYLOAD_STATE_UNSPECIFIED",
        "PAYLOAD_STATE_ALLOCATED",
        "PAYLOAD_STATE_ACTIVE",
        "PAYLOAD_STATE_SPILLING",
        "PAYLOAD_STATE_DURABLE",
        "PAYLOAD_STATE_EVICTING",
        "PAYLOAD_STATE_DELETING",
        "PAYLOAD_STATE_EXPIRED",
        "PAYLOAD_STATE_DELETED"
      ],
      "default": "PAYLOAD_STATE_UNSPECIFIED",
      "description": "Lifecycle states are monotonic.\nClients MUST NOT assume a reversible transition.\n\n - PAYLOAD_STATE_UNSPECIFIED: Not set; treated as an error.\n - PAYLOAD_STATE_ALLOCATED: Reserved; writer has not yet committed data.\n - PAYLOAD_STATE_ACTIVE: Committed and readable by consumers.\n - PAYLOAD_STATE_SPILLING: Being moved to a lower tier; temporarily locked.\n - PAYLOAD_STATE_DURABLE: Confirmed written to a durable tier (DISK/OBJECT).\n - PAYLOAD_STATE_EVICTING: Being removed from its current tier under pressure.\n - PAYLOAD_STATE_DELETING: Deletion in progress.\n - PAYLOAD_STATE_EXPIRED: TTL elapsed; pending final deletion.\n - PAYLOAD_STATE_DELETED: Fully deleted; ID is no longer valid."
    },
    "v1PromotionPolicy": {
      "type": "string",
      "enum": [
        "PROMOTION_POLICY_UNSPECIFIED",
        "PROMOTION_POLICY_BEST_EFFORT",
        "PROMOTION_POLICY_BLOCKING"
      ],
      "default": "PROMOTION_POLICY_UNSPECIFIED",
      "description": "Promotion policy controls behavior when a payload must move to a higher tier.\n\n - PROMOTION_POLICY_BEST_EFFORT: Schedule asynchronously if possible\n - PROMOTION_POLICY_BLOCKING: RPC returns only when target tier satisfied or fails"
    },
    "v1RamLocation": {
      "type": "object",
      "properties": {
        "shmName": {
          "type": "string"
        },
        "slabId": {
          "type": "integer",
          "format": "int64"
        },
        "blockIndex": {
          "type": "string",
          "format": "uint64"
        },
        "lengthBytes": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "v1ResolveSnapshotResponse": {
      "type": "object",
      "properties": {
        "payloadDescriptor": {
          "$ref": "#/definitions/v1PayloadDescriptor"
        }
      }
    },
    "v1Tier": {
      "type": "string",
      "enum": [
        "TIER_UNSPECIFIED",
        "TIER_GPU",
        "TIER_RAM",
        "TIER_DISK",
        "TIER_OBJECT"
      ],
      "default": "TIER_UNSPECIFIED",
      "description": "Ordered from fastest → most durable.\nHigher tiers may not always be available.\n\n - TIER_UNSPECIFIED: Not set; treated as an error in most contexts.\n - TIER_GPU: GPU device memory (fastest, smallest, most volatile).\n - TIER_RAM: Host DRAM / shared-memory segment.\n - TIER_DISK: Local NVMe/SSD/HDD (durable, larger, slower than RAM).\n - TIER_OBJECT: Remote object storage (S3/GCS/Azure; durable, largest)."
    }
  }
}
